# OpenProp config — copy to .env and fill what you have. Everything is optional;
# the app runs on free gov data (Census/HUD/FEMA) with no keys at all.
#
# NOTE: a comment must go ABOVE a blank key, never beside it. `KEY=  # note` makes
# the comment the value (python-dotenv only strips an inline comment after a value).

# --- single-user auth (Phase 6) ---
OPENPROP_PASSWORD=changeme        # CHANGE THIS before exposing beyond localhost
# leave blank -> a random key is generated & printed on first run
SECRET_KEY=
SESSION_HTTPS_ONLY=false          # set true when serving over HTTPS (adds Secure to the session cookie)

# --- provider selection per capability (registry.py reads these) ---
# NOTE: the /settings page writes these into the DB `setting` table, which
# OVERRIDES this file at runtime. If an edit here seems to do nothing, the DB
# has that key — change it on /settings, or `delete from setting where key=...`.
#
# reapi = the only provider whose AREA SEARCH returns a workable lead (owner,
#   value, equity, distress flags on every row). Billed per search.
# rentcast = cheap per-address detail + AVM/rent comps, but its bulk listing has
#   no value/equity/distress and is mostly blank rows in dense zips (90007: ~75
#   usable of 500). Fine for single lookups, near-useless for list building.
PROPERTY_PROVIDER=reapi           # rentcast | regrid | reapi
# batchdata | apify | reapi  (blank = skip trace disabled)
SKIPTRACE_PROVIDER=
APIFY_ACTOR=khadinakbar~skip-trace-property-owner   # actor used when SKIPTRACE_PROVIDER=apify
GEOCODER=census                   # census | nominatim

# --- API keys (bring your own; blank = that provider is inactive) ---
RENTCAST_API_KEY=
RENTCAST_FETCH_AVM=false          # false = 1 request/lookup; true adds value+rent (3 requests, burns the free 50 faster)
REGRID_API_TOKEN=
# RealEstateAPI: optional distress unlock + alt skip trace
REAPI_API_KEY=
# free token from huduser.gov
HUD_FMR_TOKEN=
# ACS median income (a free key is now required)
CENSUS_API_KEY=
# BatchData bearer token, or your Apify API token (apify_api_...)
SKIPTRACE_API_KEY=

# --- LLM (AI layer). Blank ANTHROPIC_API_KEY -> rules-based NL parser fallback. ---
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8         # or claude-haiku-4-5 for cheaper NL parsing

# --- cost guardrails ---
MONTHLY_BUDGET_CENTS=1000         # hard cap on paid provider spend per calendar month
DB_PATH=openprop.db

# --- server ---
OPENPROP_PORT=8787                # host port for run.sh / docker compose (8000 is often taken)
