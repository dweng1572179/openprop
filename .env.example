# OpenProp config — copy to .env and fill what you have. Everything is optional;
# the app runs on free gov data (Census/HUD/FEMA) with no keys at all.

# --- single-user auth (Phase 6) ---
OPENPROP_PASSWORD=changeme        # CHANGE THIS before exposing beyond localhost
SECRET_KEY=                       # leave blank -> generated & printed on first run
SESSION_HTTPS_ONLY=false          # set true when serving over HTTPS (adds Secure to the session cookie)

# --- provider selection per capability (registry.py reads these) ---
PROPERTY_PROVIDER=rentcast        # rentcast | regrid | reapi
SKIPTRACE_PROVIDER=               # batchdata | apify | reapi  (blank = skip trace disabled)
APIFY_ACTOR=khadinakbar~skip-trace-property-owner   # actor used when SKIPTRACE_PROVIDER=apify
GEOCODER=census                   # census | nominatim

# --- API keys (bring your own; blank = that provider is inactive) ---
RENTCAST_API_KEY=
RENTCAST_FETCH_AVM=false          # false = 1 request/lookup; true adds value+rent (3 requests, burns the free 50 faster)
REGRID_API_TOKEN=
REAPI_API_KEY=                    # RealEstateAPI: optional distress unlock + alt skip trace
HUD_FMR_TOKEN=                    # free token from huduser.gov
CENSUS_API_KEY=                   # ACS median income (a free key is now required)
SKIPTRACE_API_KEY=                # BatchData bearer token, or your Apify API token (apify_api_...)

# --- LLM (AI layer). Blank ANTHROPIC_API_KEY -> rules-based NL parser fallback. ---
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8         # or claude-haiku-4-5 for cheaper NL parsing

# --- cost guardrails ---
MONTHLY_BUDGET_CENTS=1000         # hard cap on paid provider spend per calendar month
DB_PATH=openprop.db

# --- server ---
OPENPROP_PORT=8787                # host port for run.sh / docker compose (8000 is often taken)
